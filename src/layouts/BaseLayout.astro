---
import '../styles/global.css';
import Analytics from '../components/layout/Analytics.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalPath?: string;
}

const {
  title,
  description = 'Distribuidor oficial Kaeser Chile. Vital Airpower entrega servicios de compresor industrial, tratamiento de aire, líneas de aire y soporte técnico corporativo con cobertura desde Copiapó hasta Rancagua.',
  ogImage = '/images/og-image.webp',
} = Astro.props;

const SITE_URL = 'https://vitalairpower.cl';
const canonicalURL = new URL(Astro.url.pathname, SITE_URL);

const schemaLocalBusiness = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': `${SITE_URL}/#business`,
  name: 'Vital Airpower Compresores',
  description: 'Distribuidor oficial Kaeser Chile y soporte corporativo para compresores industriales, tratamiento de aire y líneas de aire comprimido.',
  url: SITE_URL,
  telephone: '+56976400195',
  image: `${SITE_URL}/images/logo.webp`,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Chile',
    addressLocality: 'La Serena',
    addressRegion: 'Coquimbo',
    addressCountry: 'CL',
    postalCode: '1710000',
  },
  areaServed: [
    { '@type': 'City', name: 'Copiapó' },
    { '@type': 'City', name: 'La Serena' },
    { '@type': 'City', name: 'Rancagua' },
    { '@type': 'Country', name: 'Chile' },
  ],
  openingHoursSpecification: [{
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
    opens: '00:00',
    closes: '23:59',
  }],
  knowsAbout: ['Kaeser Chile', 'Kaeser Kompressoren', 'compresores de tornillo', 'tratamiento de aire', 'aire comprimido industrial', 'Sigma Control 2'],
};

const schemaFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Son distribuidores oficiales de Kaeser en Chile?',
      acceptedAnswer: { '@type': 'Answer', text: 'Sí. Vital Airpower es distribuidor oficial Kaeser Chile y orienta su servicio a clientes industriales que requieren respaldo técnico y continuidad operacional.' },
    },
    {
      '@type': 'Question',
      name: '¿Qué cobertura tienen para servicios y soporte?',
      acceptedAnswer: { '@type': 'Answer', text: 'Tenemos cobertura desde Copiapó hasta Rancagua para soporte técnico, proyectos de aire comprimido y acompañamiento de clientes industriales.' },
    },
    {
      '@type': 'Question',
      name: '¿Qué soluciones técnicas ofrecen?',
      acceptedAnswer: { '@type': 'Answer', text: 'Trabajamos compresores de tornillo eléctricos estacionarios, secadores de aire, filtros de línea, auditorías de fuga, líneas de aire y asesorías de eficiencia energética.' },
    },
  ],
};

const schemaBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITE_URL },
  ],
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta name="geo.region" content="CL-CO" />
    <meta name="geo.placename" content="La Serena, Chile" />
    <meta name="geo.position" content="-29.9027;-71.2519" />
    <meta name="ICBM" content="-29.9027, -71.2519" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${SITE_URL}${ogImage}`} />
    <meta property="og:image:alt" content="Vital Airpower, distribuidor oficial Kaeser Chile" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Vital Airpower Compresores" />
    <meta property="og:locale" content="es_CL" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE_URL}${ogImage}`} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/images/logo.webp" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />

    <Analytics />
  </head>
  <body class="bg-[#FCF9F8] font-[Inter] text-[#1B1C1C] antialiased">
    <slot />

    <a
      href="https://wa.me/56976400195"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Consultar por WhatsApp"
      class="fixed bottom-6 right-6 z-50 flex items-center gap-3 bg-[#25D366] text-white px-5 py-3 shadow-xl shadow-[#25D366]/30 hover:scale-105 hover:shadow-2xl transition-all duration-200 group"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 flex-shrink-0">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z" />
        <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.526 5.847L.057 23.882l6.198-1.625A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.006-1.374l-.359-.213-3.68.965.981-3.588-.234-.369A9.818 9.818 0 1112 21.818z" />
      </svg>
      <span class="font-[Space_Grotesk] font-bold text-xs tracking-widest uppercase">Consultar ahora</span>
    </a>

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('[data-animate], [data-animate-stagger]').forEach((el) => observer.observe(el));

      const counterObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target;
          const target = parseInt(el.dataset.count || '0');
          const duration = 1400;
          const start = performance.now();

          function tick(now) {
            const p = Math.min((now - start) / duration, 1);
            const eased = 1 - Math.pow(1 - p, 3);
            el.textContent = String(Math.floor(eased * target));
            if (p < 1) requestAnimationFrame(tick);
            else el.textContent = String(target);
          }

          requestAnimationFrame(tick);
          counterObs.unobserve(el);
        });
      }, { threshold: 0.5 });
      document.querySelectorAll('[data-count]').forEach((el) => counterObs.observe(el));
    </script>
  </body>
</html>
