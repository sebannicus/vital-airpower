---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalPath?: string;
}

const {
  title,
  description = 'Mantenimiento técnico especializado, reparación y contingencia 24/7 para compresores industriales en La Serena y Región de Coquimbo. 25+ años de experiencia en Atlas Copco, Ingersoll Rand y Kaeser.',
  ogImage = '/images/og-image.webp',
} = Astro.props;

const SITE_URL = 'https://vitalairpower.cl';
const canonicalURL = new URL(Astro.url.pathname, SITE_URL);

const schemaLocalBusiness = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': `${SITE_URL}/#business`,
  name: 'Vital Airpower Compresores',
  description: 'Mantenimiento, reparación y contingencia 24/7 para compresores industriales en La Serena y Región de Coquimbo.',
  url: SITE_URL,
  telephone: '+56976400195',
  image: `${SITE_URL}/images/logo.webp`,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Quilacán',
    addressLocality: 'La Serena',
    addressRegion: 'Coquimbo',
    addressCountry: 'CL',
    postalCode: '1710000',
  },
  areaServed: [
    { '@type': 'City', name: 'La Serena' },
    { '@type': 'City', name: 'Coquimbo' },
    { '@type': 'AdministrativeArea', name: 'Región de Coquimbo' },
  ],
  openingHoursSpecification: [{
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'],
    opens: '00:00',
    closes: '23:59',
  }],
  knowsAbout: ['Atlas Copco', 'Ingersoll Rand', 'Kaeser Kompressoren', 'compresores de tornillo', 'aire comprimido industrial'],
};

const schemaFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Tienen servicio de emergencia 24/7 para compresores en La Serena?',
      acceptedAnswer: { '@type': 'Answer', text: 'Sí, contamos con protocolo de contingencia activo los 365 días del año para atender paradas críticas de compresores industriales en La Serena, Coquimbo y la Región de Coquimbo.' },
    },
    {
      '@type': 'Question',
      name: '¿Qué marcas de compresores reparan?',
      acceptedAnswer: { '@type': 'Answer', text: 'Nos especializamos en Atlas Copco, Ingersoll Rand y Kaeser Kompressoren, las tres marcas líderes en compresores industriales de tornillo rotativo.' },
    },
    {
      '@type': 'Question',
      name: '¿Dónde están ubicados?',
      acceptedAnswer: { '@type': 'Answer', text: 'Tenemos taller propio en Quilacán, con cobertura hacia La Serena, Coquimbo y faenas mineras de la Región de Coquimbo.' },
    },
  ],
};

const schemaBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITE_URL },
  ],
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO primario -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Geo local -->
    <meta name="geo.region" content="CL-CO" />
    <meta name="geo.placename" content="La Serena, Chile" />
    <meta name="geo.position" content="-29.9027;-71.2519" />
    <meta name="ICBM" content="-29.9027, -71.2519" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${SITE_URL}${ogImage}`} />
    <meta property="og:image:alt" content="Vital Airpower — Compresores industriales en La Serena" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Vital Airpower Compresores" />
    <meta property="og:locale" content="es_CL" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE_URL}${ogImage}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/images/logo.webp" />

    <!-- Fuentes con display=swap (CLS safe) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Material Symbols -->
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />

    <!-- Schema JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  </head>
  <body class="bg-[#FCF9F8] font-[Inter] text-[#1B1C1C] antialiased">
    <slot />

    <!-- Botón flotante WhatsApp -->
    <a
      href="https://wa.me/56976400195"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Consultar por WhatsApp"
      class="fixed bottom-6 right-6 z-50 flex items-center gap-3 bg-[#25D366] text-white px-5 py-3 shadow-xl shadow-[#25D366]/30 hover:scale-105 hover:shadow-2xl transition-all duration-200 group"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 flex-shrink-0">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
        <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.526 5.847L.057 23.882l6.198-1.625A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.006-1.374l-.359-.213-3.68.965.981-3.588-.234-.369A9.818 9.818 0 1112 21.818z"/>
      </svg>
      <span class="font-[Space_Grotesk] font-bold text-xs tracking-widest uppercase">Consultar ahora</span>
    </a>

    <!-- Intersection Observer: scroll animations -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('[data-animate], [data-animate-stagger]').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
