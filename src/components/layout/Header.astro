---
const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/empresa', label: 'Empresa' },
  {
    href: '/servicios',
    label: 'Servicios',
    children: [
      { href: '/servicios', label: 'Servicio técnico' },
      { href: '/soluciones', label: 'Soluciones' },
    ],
  },
  { href: '/equipos', label: 'Equipos' },
  { href: '/contacto', label: 'Contacto' },
];

const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  class="fixed top-0 w-full z-50 transition-all duration-300"
  aria-label="Navegación principal"
>
  <div class="h-1 w-full bg-[#EAE7E7]">
    <div id="scroll-progress" class="h-full w-0 bg-[#003F87] transition-[width] duration-100"></div>
  </div>

  <nav class="relative bg-white/95 backdrop-blur-md border-b border-[#C2C6D4]/20 shadow-sm">
    <div class="flex justify-between items-center px-6 md:px-12 py-2 max-w-[1920px] mx-auto">
      <a href="/" class="flex items-center group" aria-label="Vital Airpower Inicio">
        <img
          src="/images/logo2.webp"
          alt="Vital Airpower Kaeser Chile"
          class="h-[88px] w-auto transition-all duration-300 group-hover:scale-105 group-hover:drop-shadow-[0_4px_12px_rgba(0,63,135,0.25)]"
        />
      </a>

      <div class="hidden md:flex items-center gap-6">
        {navLinks.map(({ href, label, children }) => (
          <div class="relative group py-4">
            <a
              href={href}
              class={[
                'font-[Space_Grotesk] uppercase tracking-widest text-[0.7rem] font-bold transition-all duration-200 relative py-1 inline-flex items-center gap-1',
                currentPath === href || (href !== '/' && currentPath.startsWith(href))
                  ? 'text-[#003F87] after:absolute after:bottom-0 after:left-0 after:w-full after:h-0.5 after:bg-[#003F87]'
                  : 'text-[#5E5E5E] hover:text-[#003F87] after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-[#003F87] after:transition-all after:duration-300 hover:after:w-full',
              ].join(' ')}
            >
              {label}
              {children && <span class="material-symbols-outlined transition-transform group-hover:rotate-180" style="font-size: 1rem;">expand_more</span>}
            </a>
            {children && (
              <div class="pointer-events-none absolute left-0 top-full min-w-64 translate-y-2 border border-[#C2C6D4]/30 bg-white p-3 opacity-0 shadow-xl shadow-[#1B1C1C]/10 transition-all duration-200 group-hover:pointer-events-auto group-hover:translate-y-0 group-hover:opacity-100">
                {children.map((child) => (
                  <a href={child.href} class="flex items-center justify-between gap-4 px-4 py-3 text-sm font-bold text-[#5E5E5E] hover:bg-[#F6F3F2] hover:text-[#003F87] transition-colors">
                    {child.label}
                    <span class="material-symbols-outlined" style="font-size: 1rem;">arrow_forward</span>
                  </a>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>

      <div class="flex items-center gap-3">
        <a
          href="/contacto"
          class="hidden sm:flex items-center gap-2 bg-[#003F87] text-white px-5 py-2.5 text-[0.7rem] font-bold tracking-widest uppercase transition-all duration-200 hover:bg-[#0056B3] hover:shadow-lg hover:shadow-[#003F87]/20 active:scale-95"
        >
          <span class="material-symbols-outlined" style="font-size: 0.95rem;">support_agent</span>
          Contacto técnico
        </a>

        <button
          id="menu-toggle"
          class="md:hidden flex flex-col gap-[5px] p-2 group"
          aria-label="Abrir menú"
          aria-expanded="false"
        >
          <span class="block w-6 h-0.5 bg-[#1B1C1C] transition-all duration-300 group-[.is-open]:rotate-45 group-[.is-open]:translate-y-[7px]"></span>
          <span class="block w-6 h-0.5 bg-[#1B1C1C] transition-all duration-300 group-[.is-open]:opacity-0"></span>
          <span class="block w-6 h-0.5 bg-[#1B1C1C] transition-all duration-300 group-[.is-open]:-rotate-45 group-[.is-open]:-translate-y-[7px]"></span>
        </button>
      </div>
    </div>

    <div
      id="mobile-menu"
      class="md:hidden overflow-hidden max-h-0 transition-[max-height] duration-300 ease-in-out bg-white border-t border-[#C2C6D4]/20"
    >
      <div class="px-6 py-6 flex flex-col gap-2">
        {navLinks.map(({ href, label, children }) => (
          <div>
            <a
              href={href}
              class={[
                'mobile-nav-link font-[Space_Grotesk] uppercase tracking-widest text-sm font-bold py-3 border-b border-[#C2C6D4]/20 transition-colors flex items-center justify-between',
                currentPath === href ? 'text-[#003F87]' : 'text-[#5E5E5E] hover:text-[#003F87]',
              ].join(' ')}
            >
              {label}
              <span class="material-symbols-outlined" style="font-size: 1rem;">arrow_forward</span>
            </a>
            {children && (
              <div class="pl-4 py-2 border-b border-[#C2C6D4]/20">
                {children.map((child) => (
                  <a href={child.href} class="mobile-nav-link block py-2 text-sm text-[#5E5E5E] hover:text-[#003F87] transition-colors">
                    {child.label}
                  </a>
                ))}
              </div>
            )}
          </div>
        ))}
        <a
          href="/contacto"
          class="mobile-nav-link mt-4 flex items-center justify-center gap-2 bg-[#003F87] text-white px-5 py-3 text-xs font-bold tracking-widest uppercase"
        >
          <span class="material-symbols-outlined" style="font-size: 1rem;">support_agent</span>
          Contacto técnico
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const progress = document.getElementById('scroll-progress');

  function closeMenu() {
    if (!menu || !toggle) return;
    menu.style.maxHeight = '0px';
    toggle.setAttribute('aria-expanded', 'false');
    toggle.classList.remove('is-open');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = menu!.style.maxHeight && menu!.style.maxHeight !== '0px';
    if (isOpen) {
      closeMenu();
    } else {
      menu!.style.maxHeight = menu!.scrollHeight + 'px';
      toggle.setAttribute('aria-expanded', 'true');
      toggle.classList.add('is-open');
    }
  });

  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  const header = document.getElementById('site-header');
  window.addEventListener(
    'scroll',
    () => {
      const max = document.documentElement.scrollHeight - window.innerHeight;
      const pct = max > 0 ? (window.scrollY / max) * 100 : 0;
      if (progress) progress.style.width = `${pct}%`;

      if (window.scrollY > 10) {
        header?.querySelector('nav')?.classList.add('shadow-md');
      } else {
        header?.querySelector('nav')?.classList.remove('shadow-md');
      }
    },
    { passive: true }
  );
</script>
