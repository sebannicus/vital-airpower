---
const services = [
  { href: '/servicios', label: 'Servicio técnico' },
  { href: '/servicios', label: 'Tratamiento de aire' },
  { href: '/soluciones', label: 'Eficiencia energética' },
  { href: '/soluciones', label: 'Líneas de aire' },
  { href: '/equipos', label: 'Equipos Kaeser' },
  { href: '/contacto', label: 'Stock crítico' },
];

const company = [
  { href: '/empresa', label: 'Sobre nosotros' },
  { href: '/equipos', label: 'Distribución oficial Kaeser' },
  { href: '/soluciones', label: 'Soluciones industriales' },
  { href: '/contacto', label: 'Contacto técnico' },
];
---

<footer class="bg-[#1B1C1C] w-full border-t border-white/10">
  <div class="grid grid-cols-1 md:grid-cols-4 gap-12 px-6 md:px-12 py-20 max-w-[1920px] mx-auto">
    <div class="space-y-6">
      <a href="/" aria-label="Vital Airpower Inicio">
        <img
          src="/images/logo2.webp"
          alt="Vital Airpower Compresores"
          width="140"
          height="70"
          class="h-[70px] w-auto brightness-0 invert opacity-90 hover:opacity-100 transition-opacity"
        />
      </a>
      <p class="text-sm leading-relaxed text-white/60 max-w-xs">
        Distribuidor oficial Kaeser Chile para proyectos corporativos, tratamiento de aire, líneas de aire comprimido y soporte técnico con cobertura desde Copiapó hasta Rancagua.
      </p>
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
        <span class="text-[0.65rem] text-white/40 uppercase font-bold tracking-widest">Cobertura desde Copiapó hasta Rancagua</span>
      </div>
    </div>

    <div class="space-y-4">
      <h5 class="text-white font-bold text-xs uppercase tracking-widest mb-6">Servicios</h5>
      <nav class="flex flex-col gap-3">
        {services.map(({ href, label }) => (
          <a href={href} class="text-sm text-white/50 hover:text-[#D7E2FF] transition-colors">{label}</a>
        ))}
      </nav>
    </div>

    <div class="space-y-4">
      <h5 class="text-white font-bold text-xs uppercase tracking-widest mb-6">Empresa</h5>
      <nav class="flex flex-col gap-3">
        {company.map(({ href, label }) => (
          <a href={href} class="text-sm text-white/50 hover:text-[#D7E2FF] transition-colors">{label}</a>
        ))}
      </nav>
    </div>

    <div class="space-y-6">
      <h5 class="text-white font-bold text-xs uppercase tracking-widest mb-6">Contacto</h5>
      <div class="space-y-4 text-sm text-white/50">
        <div class="flex items-start gap-3">
          <span class="material-symbols-outlined text-[#D7E2FF]" style="font-size: 1.1rem;">location_on</span>
          <span>Chile, cobertura desde Copiapó hasta Rancagua</span>
        </div>
        <div class="flex items-start gap-3">
          <span class="material-symbols-outlined text-[#D7E2FF]" style="font-size: 1.1rem;">call</span>
          <a href="tel:+56976400195" class="hover:text-white transition-colors">+56 9 7640 0195</a>
        </div>
        <div class="flex items-start gap-3">
          <span class="material-symbols-outlined text-[#D7E2FF]" style="font-size: 1.1rem;">mail</span>
          <a href="mailto:ops@vitalairpower.cl" class="hover:text-white transition-colors">ops@vitalairpower.cl</a>
        </div>
        <a href="https://wa.me/56976400195" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-[#25D366] text-white px-5 py-3 text-xs font-bold uppercase tracking-widest hover:bg-[#1ebe5d] transition-colors">
          <span class="material-symbols-outlined" style="font-size: 1rem;">chat</span>
          WhatsApp
        </a>
      </div>
    </div>
  </div>

  <div class="px-6 md:px-12 py-6 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4 max-w-[1920px] mx-auto">
    <p class="text-xs text-white/30 uppercase tracking-widest">
      © 2026 Vital Airpower. Distribuidor oficial Kaeser Chile.
    </p>
    <a
      href="https://gautamadigital.cl"
      target="_blank"
      rel="noopener noreferrer"
      class="text-xs text-white/30 hover:text-white/60 transition-colors"
    >
      Sitio construido por gautamadigital.cl
    </a>
  </div>
</footer>
