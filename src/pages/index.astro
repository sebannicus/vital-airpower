  <script>
    document.querySelectorAll('[data-carousel]').forEach((container) => {
      const slides = Array.from(container.querySelectorAll('[data-slide]')) as HTMLElement[];
      if (slides.length < 2) return;
      const dotsEl = container.querySelector('[data-dots]');
      let cur = 0;
      let timer: ReturnType<typeof setInterval>;
      const dots: HTMLElement[] = [];

      if (dotsEl) {
        slides.forEach((_, i) => {
          const d = document.createElement('button');
          d.className = `h-1.5 rounded-full transition-all duration-300 ${i === 0 ? 'w-5 bg-white' : 'w-1.5 bg-white/40'}`;
          d.setAttribute('aria-label', `Slide ${i + 1}`);
          d.addEventListener('click', () => { go(i); reset(); });
          dotsEl.appendChild(d);
          dots.push(d);
        });
      }

      function go(n: number) {
        slides[cur].style.opacity = '0'; slides[cur].style.zIndex = '0';
        cur = ((n % slides.length) + slides.length) % slides.length;
        slides[cur].style.opacity = '1'; slides[cur].style.zIndex = '1';
        dots.forEach((d, i) => {
          d.className = `h-1.5 rounded-full transition-all duration-300 ${i === cur ? 'w-5 bg-white' : 'w-1.5 bg-white/40'}`;
        });
      }

      function start() { timer = setInterval(() => go(cur + 1), 3000); }
      function reset() { clearInterval(timer); start(); }

      container.querySelector('[data-prev]')?.addEventListener('click', () => { go(cur - 1); reset(); });
      container.querySelector('[data-next]')?.addEventListener('click', () => { go(cur + 1); reset(); });
      container.addEventListener('mouseenter', () => clearInterval(timer));
      container.addEventListener('mouseleave', start);
      start();
    });
  </script>
