---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const highlights = [
  'Distribuidor oficial Kaeser Chile con foco en clientes industriales.',
  'Cobertura desde Copiapó hasta Rancagua.',
  'Servicios de compresor industrial, tratamiento de aire y líneas de aire.',
];

const keyServices = [
  {
    title: 'Servicios técnicos',
    text: 'Mantenimiento, diagnóstico y soporte para compresores, secadores y filtros con criterio industrial.',
    href: '/servicios',
  },
  {
    title: 'Soluciones de sistema',
    text: 'Eficiencia energética, tratamiento de aire, control y proyección de líneas de aire comprimido.',
    href: '/soluciones',
  },
  {
    title: 'Equipos Kaeser',
    text: 'Familias de equipos, rangos de trabajo y configuraciones relevantes para distintas escalas de operación.',
    href: '/equipos',
  },
];

const gallerySlots = [
  { title: 'Sala de compresores', src: '/images/planta-de-aire.webp' },
  { title: 'Equipo Kaeser en planta', src: '/images/kaeser-csd105.webp' },
  { title: 'Mantención técnica', src: '/images/cambio-de-filtro.webp' },
  { title: 'Tratamiento de aire', src: '/images/filtro-compresor.webp' },
  { title: 'Líneas de aire', src: '/images/manguera-compresor.webp' },
  { title: 'Operación industrial', src: '/images/compresor-planta.webp' },
];

const faqs = [
  {
    question: '¿Son distribuidores oficiales de Kaeser en Chile?',
    answer: 'Sí. Vital Airpower opera como distribuidor oficial Kaeser Chile con una propuesta orientada a empresas y continuidad operacional.',
  },
  {
    question: '¿Qué cobertura tienen?',
    answer: 'Atendemos clientes desde Copiapó hasta Rancagua, con foco en soporte técnico, proyectos y acompañamiento comercial.',
  },
  {
    question: '¿Qué tipo de servicio ofrece Vital Airpower?',
    answer: 'Servicio técnico para compresores industriales, tratamiento de aire, líneas de aire, eficiencia energética y soporte operacional.',
  },
  {
    question: '¿Atienden compresores de tornillo eléctricos estacionarios?',
    answer: 'Sí. La propuesta técnica considera compresores de tornillo eléctricos estacionarios y sistemas asociados al aire comprimido industrial.',
  },
  {
    question: '¿Trabajan secadores y filtros de línea?',
    answer: 'Sí. Vital Airpower considera tratamiento de aire mediante secadores por refrigeración o absorción, filtros de línea y componentes de protección del sistema.',
  },
  {
    question: '¿Realizan auditorías de fuga?',
    answer: 'Sí. Se contemplan auditorías de fugas por ultrasonido para detectar pérdidas y apoyar decisiones de eficiencia energética.',
  },
  {
    question: '¿Pueden proyectar líneas de aire comprimido?',
    answer: 'Sí. Se puede apoyar la creación, mantención y proyección de líneas de aire para ordenar el crecimiento del sistema.',
  },
  {
    question: '¿Manejan stock crítico para contratos?',
    answer: 'Sí. Para clientes con contratos de servicio, repuestos o mantenimiento se puede coordinar stock crítico para reducir riesgos de detención.',
  },
];
---

<BaseLayout
  title="Vital Airpower | Distribuidor oficial Kaeser Chile y servicios de compresor industrial"
  description="Vital Airpower es distribuidor oficial Kaeser Chile. Servicios corporativos para compresores industriales, tratamiento de aire, líneas de aire y soporte técnico con cobertura desde Copiapó hasta Rancagua."
>
  <Header />

  <main class="pt-[96px] bg-[#f4f1eb]">
    <section id="sobre-nosotros" class="relative overflow-hidden border-b border-[#0f3d2f]/10 bg-[linear-gradient(135deg,#f4f1eb_0%,#ebe7df_54%,#ddd4c6_100%)]">
      <div class="absolute inset-0 opacity-[0.08] pointer-events-none bg-[radial-gradient(circle_at_top_left,_#0f3d2f_0,_transparent_32%),radial-gradient(circle_at_bottom_right,_#c79a3b_0,_transparent_28%)]"></div>
      <div class="relative max-w-[1440px] mx-auto px-6 md:px-12 py-18 md:py-24 grid lg:grid-cols-[1.1fr_0.9fr] gap-12 items-center">
        <div>
          <p class="font-[Space_Grotesk] text-[0.7rem] font-bold uppercase tracking-[0.2em] text-[#0f3d2f] mb-4">Sobre Nosotros</p>
          <h1 class="max-w-4xl text-4xl md:text-6xl font-bold tracking-tight text-[#17211c] leading-[1.02] mb-6">
            Vital Airpower articula soluciones industriales con Kaeser como eje principal.
          </h1>
          <p class="max-w-2xl text-lg md:text-xl leading-relaxed text-[#3f4a43] mb-8">
            Somos distribuidores oficiales Kaeser Chile y trabajamos para empresas que necesitan soporte técnico, información clara y una operación de aire comprimido más ordenada. Acompañamos proyectos, mantenciones y decisiones de eficiencia con una mirada corporativa y técnica.
          </p>
          <div class="grid sm:grid-cols-3 gap-4 mb-8">
            <div class="border border-[#0f3d2f]/10 bg-white/70 p-5">
              <p class="text-[0.7rem] uppercase tracking-[0.18em] font-bold text-[#7a6b57] mb-2">Cobertura</p>
              <p class="text-2xl font-bold text-[#17211c]">Copiapó</p>
              <p class="text-sm text-[#546056]">hasta Rancagua</p>
            </div>
            <div class="border border-[#0f3d2f]/10 bg-white/70 p-5">
              <p class="text-[0.7rem] uppercase tracking-[0.18em] font-bold text-[#7a6b57] mb-2">Enfoque</p>
              <p class="text-2xl font-bold text-[#17211c]">Kaeser</p>
              <p class="text-sm text-[#546056]">distribución oficial</p>
            </div>
            <div class="border border-[#0f3d2f]/10 bg-white/70 p-5">
              <p class="text-[0.7rem] uppercase tracking-[0.18em] font-bold text-[#7a6b57] mb-2">Perfil</p>
              <p class="text-2xl font-bold text-[#17211c]">B2B</p>
              <p class="text-sm text-[#546056]">corporativo y técnico</p>
            </div>
          </div>
          <div class="flex flex-wrap gap-4">
            <a href="/contacto" class="inline-flex items-center gap-3 bg-[#0f3d2f] text-white px-7 py-4 text-sm font-bold uppercase tracking-[0.16em] hover:bg-[#174c3b] transition-colors">
              Solicitar asesoría técnica
              <span class="material-symbols-outlined" style="font-size: 1rem;">arrow_forward</span>
            </a>
            <a href="/empresa" class="inline-flex items-center gap-3 border border-[#0f3d2f]/20 text-[#0f3d2f] px-7 py-4 text-sm font-bold uppercase tracking-[0.16em] bg-white/70 hover:bg-white transition-colors">
              Conocer la empresa
            </a>
          </div>
        </div>

        <div class="grid gap-4">
          <div class="relative overflow-hidden min-h-[360px] border border-[#0f3d2f]/10 bg-[#17211c]">
            <img
              src="/images/hero-kaeser.webp"
              alt="Equipo Kaeser en entorno industrial"
              width="900"
              height="900"
              class="absolute inset-0 h-full w-full object-cover opacity-60"
            />
            <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(23,33,28,0.18)_0%,rgba(23,33,28,0.82)_100%)]"></div>
            <div class="relative z-10 flex h-full flex-col justify-end p-8">
              <img src="/images/logo-kaeser.webp" alt="Kaeser" width="168" height="44" class="h-10 w-auto object-contain mb-5" />
              <p class="text-sm uppercase tracking-[0.18em] font-bold text-[#e3d6be] mb-2">Distribuidor oficial Kaeser Chile</p>
              <p class="text-white text-lg leading-relaxed max-w-md">
                Calidad, eficiencia y respaldo técnico para compañías que dependen del aire comprimido como parte crítica de su operación.
              </p>
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-4">
            {highlights.map((item) => (
              <div class="border border-[#0f3d2f]/10 bg-white p-5">
                <div class="flex items-start gap-3">
                  <span class="material-symbols-outlined text-[#0f3d2f]" style="font-size: 1.15rem;">verified</span>
                  <p class="text-sm leading-relaxed text-[#2f3a34]">{item}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white border-b border-[#0f3d2f]/8">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-18 md:py-24">
        <div class="max-w-3xl mb-12">
          <p class="font-[Space_Grotesk] text-[0.7rem] font-bold uppercase tracking-[0.2em] text-[#7a6b57] mb-4">Servicios principales</p>
          <h2 class="text-3xl md:text-5xl font-bold text-[#17211c] tracking-tight mb-6">
            Una estructura simple para encontrar rápido la información que necesita su operación.
          </h2>
          <p class="text-[#4f5a53] text-lg leading-relaxed">
            Desde la evaluación técnica hasta la selección de equipos, Vital Airpower ordena la conversación según el escenario real del cliente: servicio, solución de sistema o equipamiento Kaeser.
          </p>
        </div>
        <div class="grid md:grid-cols-3 gap-5">
          {keyServices.map((item) => (
            <article class="border border-[#0f3d2f]/10 bg-[#f8f6f1] p-7 min-h-[230px] flex flex-col justify-between">
              <div>
                <span class="material-symbols-outlined text-[#0f3d2f] mb-5 block" style="font-size: 1.5rem;">overview</span>
                <h3 class="text-xl font-bold text-[#17211c] mb-3">{item.title}</h3>
                <p class="text-[#4f5a53] leading-relaxed">{item.text}</p>
              </div>
              <a href={item.href} class="inline-flex items-center gap-2 text-[#0f3d2f] font-bold uppercase text-xs tracking-[0.16em] mt-8">
                Ver mas
                <span class="material-symbols-outlined" style="font-size: 1rem;">arrow_forward</span>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="border-b border-[#0f3d2f]/8 bg-[#17211c] text-white">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-18 md:py-24 grid lg:grid-cols-[1fr_1fr] gap-12 items-start">
        <div>
          <p class="font-[Space_Grotesk] text-[0.7rem] uppercase tracking-[0.2em] font-bold text-[#d5c6ac] mb-4">Capacidad de soporte</p>
          <h2 class="text-3xl md:text-5xl font-bold tracking-tight mb-6">Vital Airpower conecta servicio, equipos y criterio técnico.</h2>
          <p class="text-white/72 text-lg leading-relaxed mb-8">
            Trabajamos compresores de tornillo eléctricos estacionarios, secadores de aire, filtros de línea, líneas de aire comprimido, auditorías de fuga y soporte operacional para clientes con necesidades de continuidad y eficiencia.
          </p>
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          {[
            'Compresores de tornillo eléctricos estacionarios.',
            'Secadores de aire por refrigeración y absorción.',
            'Tratamiento de aire con filtros de línea.',
            'Creación, mantención y proyección de líneas de aire.',
            'Auditorías de fugas por ultrasonido.',
            'Control de stock crítico para contratos de servicio.',
          ].map((item) => (
            <div class="border border-white/10 bg-white/5 p-6">
              <div class="flex items-start gap-3">
                <span class="material-symbols-outlined text-[#e3d6be]" style="font-size: 1.15rem;">manufacturing</span>
                <p class="text-white/82 leading-relaxed">{item}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="galeria" class="bg-white border-b border-[#0f3d2f]/8">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-18 md:py-24">
        <div class="max-w-3xl mb-12">
          <p class="font-[Space_Grotesk] text-[0.7rem] font-bold uppercase tracking-[0.2em] text-[#7a6b57] mb-4">Galeria</p>
          <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-[#17211c] mb-6">
            Espacios preparados para imágenes de proyectos, equipos e instalaciones.
          </h2>
          <p class="text-[#4f5a53] text-lg leading-relaxed">
            Esta seccion queda lista para reemplazar las imagenes actuales por registros propios de Vital Airpower. Cada espacio conserva proporcion, lectura y jerarquia visual.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {gallerySlots.map((item, index) => (
            <figure class="group relative overflow-hidden border border-[#0f3d2f]/10 bg-[#ebe7df] min-h-[260px]">
              <img src={item.src} alt={item.title} width="720" height="540" class="absolute inset-0 h-full w-full object-cover opacity-70 transition-transform duration-700 group-hover:scale-105" />
              <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(23,33,28,0.08)_0%,rgba(23,33,28,0.82)_100%)]"></div>
              <figcaption class="relative z-10 flex h-full min-h-[260px] flex-col justify-end p-6 text-white">
                <span class="mb-3 inline-flex w-fit bg-white/14 px-3 py-1 text-[0.65rem] font-bold uppercase tracking-[0.18em] text-white/80">Espacio sin rellenar {index + 1}</span>
                <p class="font-[Space_Grotesk] text-xl font-bold">{item.title}</p>
                <p class="mt-2 text-sm text-white/68">Imagen referencial reemplazable.</p>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section id="faq" class="bg-[#f4f1eb]">
      <div class="max-w-[1100px] mx-auto px-6 md:px-12 py-18 md:py-24">
        <div class="max-w-2xl mb-12">
          <p class="font-[Space_Grotesk] text-[0.7rem] font-bold uppercase tracking-[0.2em] text-[#7a6b57] mb-4">Preguntas y respuestas</p>
          <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-[#17211c] mb-6">Respuestas rápidas para clientes que buscan compresores Kaeser y soporte industrial.</h2>
        </div>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <details class="group border border-[#0f3d2f]/12 bg-white px-6 py-5">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left text-lg font-bold text-[#17211c]">
                <span>{faq.question}</span>
                <span class="material-symbols-outlined text-[#0f3d2f] transition-transform group-open:rotate-45">add</span>
              </summary>
              <p class="pt-4 pr-8 leading-relaxed text-[#4f5a53]">{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
