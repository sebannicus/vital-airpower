---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const faqs = [
  {
    question: '¿Son distribuidores oficiales de Kaeser en Chile?',
    answer: 'Sí. Vital Airpower opera como distribuidor oficial Kaeser Chile para la Región de Coquimbo, con acceso directo al catálogo completo y soporte técnico de la marca.',
  },
  {
    question: '¿Atienden compresores de otras marcas además de Kaeser?',
    answer: 'Sí. Vital Airpower acumula 25 años de experiencia técnica en Atlas Copco e Ingersoll Rand antes de ser distribuidor Kaeser. Damos servicio técnico a compresores de esas marcas y otras que ya operan en su planta, sin importar la marca.',
  },
  {
    question: '¿Qué cobertura geográfica tienen?',
    answer: 'La Serena, Coquimbo y faenas mineras del norte chico, con base técnica propia en Quilacán, Región de Coquimbo.',
  },
  {
    question: '¿Qué tipo de compresores venden?',
    answer: 'Toda la gama Kaeser: tornillo con inyección de aceite, tornillo seco, pistón, portátiles MOBILAIR y sopladores. Desde 2,2 hasta 515 kW en compresores de tornillo.',
  },
  {
    question: '¿Trabajan secadores y filtros de línea?',
    answer: 'Sí. Consideramos tratamiento de aire completo: secadores por refrigeración y adsorción, filtros de línea, drenajes de condensado y separadores agua-aceite AQUAMAT.',
  },
  {
    question: '¿Realizan auditorías de fuga por ultrasonido?',
    answer: 'Sí. El levantamiento por ultrasonido detecta pérdidas en la red para apoyar decisiones de eficiencia energética y reducción de costos operativos.',
  },
  {
    question: '¿Pueden proyectar líneas de aire comprimido?',
    answer: 'Sí. Instalamos y proyectamos redes SmartPipe+ de aluminio modular, desde pequeños locales hasta instalaciones industriales de gran escala.',
  },
  {
    question: '¿Tienen contingencia fuera de horario hábil?',
    answer: 'Sí. La contingencia 24/7 está disponible para emergencias de parada en planta. El canal directo es WhatsApp para respuesta inmediata.',
  },
];
---

<BaseLayout
  title="Vital Airpower | Distribuidor oficial Kaeser Chile — Compresores y servicio técnico industrial"
  description="Vital Airpower: distribuidor oficial Kaeser Chile. Compresores de tornillo, pistón, sopladores, tratamiento de aire y servicio técnico 24/7 en La Serena, Coquimbo y norte chico."
>
  <Header />

  <main class="pt-[96px] bg-[#f4f1eb]">

    <!-- ═══════════════════════════════ HERO ═══════════════════════════════ -->
    <section class="relative min-h-[92vh] flex items-center overflow-hidden">
      <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-r from-[#070e1a]/92 via-[#070e1a]/68 to-[#070e1a]/25 z-10"></div>
        <div class="absolute inset-0 bg-grid-hero z-20 pointer-events-none"></div>
        <img
          src="/images/CES_Banner_47-52450.webp"
          alt="Vital Airpower — Sistemas de aire comprimido industrial"
          class="absolute inset-0 w-full h-full object-cover ken-burns"
          width="1920" height="1080" loading="eager"
        />
      </div>
      <div class="relative z-30 max-w-[1440px] mx-auto px-6 md:px-12 py-24 grid md:grid-cols-12 gap-12">
        <div class="md:col-span-8 lg:col-span-7">
          <span class="animate-hero inline-block px-3 py-1 bg-[#D7E2FF] text-[#003F87] text-[10px] font-bold tracking-[0.2em] uppercase mb-6">
            Distribuidor Oficial Kaeser Chile
          </span>
          <h1 class="animate-hero-delay-1 font-[Space_Grotesk] text-5xl md:text-7xl font-bold text-white leading-[1.05] tracking-tighter mb-8">
            Soluciones técnicas para que su operación no se detenga
          </h1>
          <p class="animate-hero-delay-2 text-white/80 text-xl max-w-xl mb-10 font-light leading-relaxed">
            Compresores Kaeser, servicio técnico 24/7 y toda la gama de aire comprimido industrial. Cobertura en La Serena, Coquimbo y norte chico.
          </p>
          <div class="animate-hero-delay-3 flex flex-wrap gap-4">
            <a href="/contacto" class="flex items-center gap-3 bg-[#003F87] text-white px-8 py-4 font-bold text-sm tracking-widest uppercase hover:bg-[#0056B3] hover:shadow-lg hover:shadow-[#003F87]/30 hover:-translate-y-0.5 transition-all duration-200">
              Solicitar asesoría técnica
              <span class="material-symbols-outlined" style="font-size:1.1rem;">arrow_forward</span>
            </a>
            <a href="/equipos" class="border border-white/30 text-white px-8 py-4 font-bold text-sm tracking-widest uppercase hover:bg-white/10 hover:-translate-y-0.5 transition-all duration-200">
              Ver equipos
            </a>
          </div>
          <!-- Kaeser quality badges -->
          <div class="mt-10 pt-8 border-t border-white/15 grid grid-cols-2 sm:grid-cols-4 gap-5">
            {[
              { icon: 'energy_savings_leaf', text: 'Más aire por menos energía' },
              { icon: 'build_circle',        text: 'Mantenimiento simple y rápido' },
              { icon: 'workspace_premium',   text: 'Made in Germany' },
              { icon: 'public',              text: 'Red de asistencia mundial' },
            ].map((b) => (
              <div class="flex items-center gap-2.5">
                <span class="material-symbols-outlined text-[#D7E2FF] flex-shrink-0" style="font-size:1.25rem;">{b.icon}</span>
                <span class="text-white/65 text-xs font-bold leading-tight">{b.text}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════ EXPERIENCIA TÉCNICA STRIP ════════════════ -->
    <section class="bg-[#17211c] border-b border-white/8">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-10 grid md:grid-cols-[1fr_auto] gap-8 items-center">
        <div class="grid sm:grid-cols-[1fr_auto] gap-6 items-center">
          <div>
            <p class="text-[0.68rem] font-bold uppercase tracking-[0.2em] text-[#d5c6ac] mb-1">Vital Airpower — Servicio técnico multi-marca</p>
            <p class="text-white text-lg font-bold">25 años en terreno con las marcas líderes. Mantenemos cualquier compresor que ya tenga en planta.</p>
          </div>
          <div class="hidden sm:flex items-center gap-6 flex-shrink-0">
            <div class="text-center">
              <p class="text-2xl font-bold text-white">7 años</p>
              <p class="text-[0.62rem] text-white/40 uppercase tracking-widest">Atlas Copco</p>
            </div>
            <div class="w-px h-8 bg-white/10"></div>
            <div class="text-center">
              <p class="text-2xl font-bold text-white">12 años</p>
              <p class="text-[0.62rem] text-white/40 uppercase tracking-widest">Ingersoll Rand</p>
            </div>
            <div class="w-px h-8 bg-white/10"></div>
            <div class="text-center">
              <p class="text-2xl font-bold text-[#D7E2FF]">Hoy</p>
              <p class="text-[0.62rem] text-[#D7E2FF]/60 uppercase tracking-widest">Kaeser</p>
            </div>
          </div>
        </div>
        <a href="/servicios" class="flex-shrink-0 inline-flex items-center gap-2 border border-white/15 text-white/70 hover:text-white hover:border-white/30 px-5 py-3 text-xs font-bold uppercase tracking-widest transition-colors">
          Ver servicios técnicos
          <span class="material-symbols-outlined" style="font-size:1rem;">arrow_forward</span>
        </a>
      </div>
    </section>

    <!-- ═══════════════════════════ PRODUCTOS KAESER HEADER ════════════════ -->
    <section class="py-16 md:py-20 px-6 md:px-12 bg-[#f4f1eb] border-b border-[#0f3d2f]/10">
      <div class="max-w-[1440px] mx-auto grid md:grid-cols-[1fr_0.5fr] gap-8 items-end">
        <div>
          <p class="font-[Space_Grotesk] text-[0.7rem] font-bold uppercase tracking-[0.2em] text-[#7a6b57] mb-4">Productos KAESER — Distribuidor Oficial Chile</p>
          <h2 class="font-[Space_Grotesk] text-3xl md:text-5xl font-bold tracking-tight text-[#17211c] leading-[1.05]">
            Equipos Kaeser para los que necesitan uno nuevo. Mantención para los que ya tienen uno.
          </h2>
        </div>
        <p class="text-[#4f5a53] text-base leading-relaxed">
          Da igual si se trata de un Kaeser, un Atlas Copco o un Ingersoll Rand: Vital Airpower lo mantiene, lo repara y lo respalda. Y si necesita un equipo nuevo, somos distribuidores oficiales Kaeser Chile.
        </p>
      </div>
    </section>

    <!-- ══════════════════ CATEGORÍA 1: COMPRESORES DE TORNILLO ═══════════ -->
    <section class="border-b border-[#0f3d2f]/8 bg-white">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16 md:py-20">
        <div class="grid lg:grid-cols-2 gap-8 md:gap-12 items-start">
          <div>
            <p class="font-[Space_Grotesk] text-[0.68rem] font-bold uppercase tracking-[0.2em] text-[#003F87] mb-3">Kaeser / Compresores de tornillo</p>
            <h2 class="font-[Space_Grotesk] text-3xl md:text-4xl font-bold tracking-tight text-[#17211c] mb-4">
              Presión constante.<br />Eficiencia energética real.
            </h2>
            <p class="text-[#4f5a53] leading-relaxed mb-6">
              El <strong>Perfil SIGMA</strong> de KAESER permite ahorrar hasta un 15% de energía frente a perfiles de tornillo convencionales. Desde 2,2 hasta 515 kW para talleres, industria, minería y refinería. Alta disponibilidad del aire y bajos costos cíclicos a lo largo de toda la vida útil.
            </p>
            <div class="space-y-2">
              <details class="group border border-[#0f3d2f]/10 bg-[#f8f6f1] hover:border-[#003F87]/20 transition-colors">
                <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none">
                  <span class="text-sm font-bold text-[#17211c]">Con inyección de aceite</span>
                  <span class="material-symbols-outlined text-[#003F87] transition-transform duration-300 group-open:rotate-45 flex-shrink-0" style="font-size:1rem;">add</span>
                </summary>
                <div class="px-5 pb-4 pt-0 text-sm text-[#4f5a53] leading-relaxed">
                  Desde 2,2 hasta 515 kW. Servicio confiable hasta 45°C de temperatura ambiente. Acceso rápido a puntos de mantenimiento. La opción más utilizada en industria y minería.
                </div>
              </details>
              <details class="group border border-[#0f3d2f]/10 bg-[#f8f6f1] hover:border-[#003F87]/20 transition-colors">
                <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none">
                  <span class="text-sm font-bold text-[#17211c]">Libres de aceite CSG-2 / DSG-2</span>
                  <span class="material-symbols-outlined text-[#003F87] transition-transform duration-300 group-open:rotate-45 flex-shrink-0" style="font-size:1rem;">add</span>
                </summary>
                <div class="px-5 pb-4 pt-0 text-sm text-[#4f5a53] leading-relaxed">
                  Aire limpio para procesos críticos. Sin aceite en el proceso. Opcionalmente con secador i.HOC integrado o secador refrigerativo eficiente.
                </div>
              </details>
              <details class="group border border-[#0f3d2f]/10 bg-[#f8f6f1] hover:border-[#003F87]/20 transition-colors">
                <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none">
                  <span class="text-sm font-bold text-[#17211c]">Bombas de vacío de tornillo</span>
                  <span class="material-symbols-outlined text-[#003F87] transition-transform duration-300 group-open:rotate-45 flex-shrink-0" style="font-size:1rem;">add</span>
                </summary>
                <div class="px-5 pb-4 pt-0 text-sm text-[#4f5a53] leading-relaxed">
                  Caudal de 4,75 hasta 15,70 m³/min. Vacío final: 99%. Equipados con motores de alta eficiencia IE3. Fácil instalación.
                </div>
              </details>
              <details class="group border border-[#0f3d2f]/10 bg-[#f8f6f1] hover:border-[#003F87]/20 transition-colors">
                <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none">
                  <span class="text-sm font-bold text-[#17211c]">Recuperación del calor</span>
                  <span class="material-symbols-outlined text-[#003F87] transition-transform duration-300 group-open:rotate-45 flex-shrink-0" style="font-size:1rem;">add</span>
                </summary>
                <div class="px-5 pb-4 pt-0 text-sm text-[#4f5a53] leading-relaxed">
                  Un compresor de tornillo convierte en calor el 100% de la energía suministrada. Hasta un 96% puede recuperarse para aplicaciones termotécnicas, reduciendo significativamente los costos totales.
                </div>
              </details>
            </div>
            <a href="/contacto" class="inline-flex items-center gap-2 mt-6 text-[#003F87] font-bold text-xs uppercase tracking-widest hover:gap-3 transition-all duration-200">
              Consultar disponibilidad
              <span class="material-symbols-outlined" style="font-size:1rem;">arrow_forward</span>
            </a>
          </div>
          <div data-carousel class="relative overflow-hidden bg-[#17211c]">
            <div class="relative" style="aspect-ratio:4/3;">
              {[
                { src: '/images/kaeser-csd105.webp',   alt: 'Kaeser CSD 105' },
                { src: '/images/kaeser-ask32t.webp',   alt: 'Kaeser ASK 32 T' },
                { src: '/images/kaeser-sk25t.webp',    alt: 'Kaeser SK 25 T' },
                { src: '/images/kaeser-sm12.webp',     alt: 'Kaeser SM 12' },
                { src: '/images/kaeser-csd-series.webp', alt: 'Kaeser CSD Series' },
              ].map((img, i) => (
                <div data-slide class="absolute inset-0 transition-opacity duration-700" style={i === 0 ? 'opacity:1;z-index:1' : 'opacity:0;z-index:0'}>
                  <img src={img.src} alt={img.alt} class="absolute inset-0 w-full h-full object-cover" loading={i === 0 ? 'eager' : 'lazy'} />
                </div>
              ))}
            </div>
            <button data-prev aria-label="Anterior" class="absolute left-3 top-1/2 -translate-y-1/2 z-20 w-9 h-9 bg-black/40 hover:bg-[#003F87] text-white flex items-center justify-center transition-colors">
              <span class="material-symbols-outlined" style="font-size:1.2rem;">chevron_left</span>
            </button>
            <button data-next aria-label="Siguiente" class="absolute right-3 top-1/2 -translate-y-1/2 z-20 w-9 h-9 bg-black/40 hover:bg-[#003F87] text-white flex items-center justify-center transition-colors">
              <span class="material-symbols-outlined" style="font-size:1.2rem;">chevron_right</span>
            </button>
            <div data-dots class="absolute bottom-3 left-1/2 -translate-x-1/2 z-20 flex gap-1.5"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════ CATEGORÍA 2: COMPRESORES DE PISTÓN ══════════════ -->
    <section class="border-b border-[#0f3d2f]/8 bg-[#f4f1eb]">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16 md:py-20">
        <div class="grid lg:grid-cols-2 gap-8 md:gap-12 items-start">
          <div>
            <p class="font-[Space_Grotesk] text-[0.68rem] font-bold uppercase tracking-[0.2em] text-[#003F87] mb-3">Kaeser / Compresores de pistón</p>
            <h2 class="font-[Space_Grotesk] text-3xl md:text-4xl font-bold tracking-tight text-[#17211c] mb-4">
              Los especialistas cuando la demanda es variable.
            </h2>
            <p class="text-[#4f5a53] leading-relaxed mb-6">
              Ciclo ideal de conexión entre 60 y 70%. La mejor elección para funcionamiento fluctuante con puntas de carga, industrias artesanales, talleres y pequeñas empresas. Los Boosters pueden comprimir el aire hasta 45 bar en puntos determinados de la red.
            </p>
            <div class="space-y-2">
              <details class="group border border-[#0f3d2f]/10 bg-white hover:border-[#003F87]/20 transition-colors">
                <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none">
                  <span class="text-sm font-bold text-[#17211c]">Portátiles i.Comp</span>
                  <span class="material-symbols-outlined text-[#003F87] transition-transform duration-300 group-open:rotate-45 flex-shrink-0" style="font-size:1rem;">add</span>
                </summary>
                <div class="px-5 pb-4 pt-0 text-sm text-[#4f5a53] leading-relaxed">
                  Presión constante hasta 11 bar. Versiones PREMIUM y CLASSIC. Caudal desde 130 hasta 660 l/min. Para obras y pequeñas empresas.
                </div>
              </details>
              <details class="group border border-[#0f3d2f]/10 bg-white hover:border-[#003F87]/20 transition-colors">
                <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none">
                  <span class="text-sm font-bold text-[#17211c]">Estacionarios</span>
                  <span class="material-symbols-outlined text-[#003F87] transition-transform duration-300 group-open:rotate-45 flex-shrink-0" style="font-size:1rem;">add</span>
                </summary>
                <div class="px-5 pb-4 pt-0 text-sm text-[#4f5a53] leading-relaxed">
                  Con lubricación por aceite o sin aceite (OIL.FREE). Caudal 59–1.400 l/min. Presiones 7, 10, 15 o 35 bar. Numerosas variantes y potencias.
                </div>
              </details>
              <details class="group border border-[#0f3d2f]/10 bg-white hover:border-[#003F87]/20 transition-colors">
                <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none">
                  <span class="text-sm font-bold text-[#17211c]">Equipos completos — i.Comp Tower / AIRBOX</span>
                  <span class="material-symbols-outlined text-[#003F87] transition-transform duration-300 group-open:rotate-45 flex-shrink-0" style="font-size:1rem;">add</span>
                </summary>
                <div class="px-5 pb-4 pt-0 text-sm text-[#4f5a53] leading-relaxed">
                  Libres de aceite. Listos para la puesta en marcha. Para laboratorios, farmacéutica, bebidas y alimentación. Caudal 0,25–0,90 m³/min.
                </div>
              </details>
              <details class="group border border-[#0f3d2f]/10 bg-white hover:border-[#003F87]/20 transition-colors">
                <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none">
                  <span class="text-sm font-bold text-[#17211c]">Boosters</span>
                  <span class="material-symbols-outlined text-[#003F87] transition-transform duration-300 group-open:rotate-45 flex-shrink-0" style="font-size:1rem;">add</span>
                </summary>
                <div class="px-5 pb-4 pt-0 text-sm text-[#4f5a53] leading-relaxed">
                  Elevan la presión de la red existente para una parte del caudal. Como componentes separados o sistemas completos. Para presiones altas y constantes hasta 45 bar.
                </div>
              </details>
            </div>
            <a href="/contacto" class="inline-flex items-center gap-2 mt-6 text-[#003F87] font-bold text-xs uppercase tracking-widest hover:gap-3 transition-all duration-200">
              Consultar disponibilidad
              <span class="material-symbols-outlined" style="font-size:1rem;">arrow_forward</span>
            </a>
          </div>
          <div data-carousel class="relative overflow-hidden bg-[#17211c]">
            <div class="relative" style="aspect-ratio:4/3;">
              <div data-slide class="absolute inset-0 transition-opacity duration-700" style="opacity:1;z-index:1;">
                <img src="/images/servicios-portada.webp" alt="Compresor de pistón Kaeser" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
              </div>
              <div data-slide class="absolute inset-0 transition-opacity duration-700" style="opacity:0;z-index:0;">
                <img src="/images/servicios-portada2.webp" alt="Equipo Kaeser en taller" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
              </div>
              <div data-slide class="absolute inset-0 transition-opacity duration-700" style="opacity:0;z-index:0;">
                <div class="w-full h-full bg-[#1a2228] flex items-center justify-center">
                  <div class="text-center opacity-20">
                    <span class="material-symbols-outlined text-white block mb-2" style="font-size:2.5rem;">image</span>
                    <p class="text-white text-xs tracking-widest uppercase">Imagen próximamente</p>
                  </div>
                </div>
              </div>
              <div data-slide class="absolute inset-0 transition-opacity duration-700" style="opacity:0;z-index:0;">
                <div class="w-full h-full bg-[#1a2228] flex items-center justify-center">
                  <div class="text-center opacity-20">
                    <span class="material-symbols-outlined text-white block mb-2" style="font-size:2.5rem;">image</span>
                    <p class="text-white text-xs tracking-widest uppercase">Imagen próximamente</p>
                  </div>
                </div>
              </div>
            </div>
            <button data-prev aria-label="Anterior" class="absolute left-3 top-1/2 -translate-y-1/2 z-20 w-9 h-9 bg-black/40 hover:bg-[#003F87] text-white flex items-center justify-center transition-colors">
              <span class="material-symbols-outlined" style="font-size:1.2rem;">chevron_left</span>
            </button>
            <button data-next aria-label="Siguiente" class="absolute right-3 top-1/2 -translate-y-1/2 z-20 w-9 h-9 bg-black/40 hover:bg-[#003F87] text-white flex items-center justify-center transition-colors">
              <span class="material-symbols-outlined" style="font-size:1.2rem;">chevron_right</span>
            </button>
            <div data-dots class="absolute bottom-3 left-1/2 -translate-x-1/2 z-20 flex gap-1.5"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════ CATEGORÍA 3: SOPLADORES ══════════════════ -->
    <section class="border-b border-[#0f3d2f]/8 bg-white">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16 md:py-20">
        <div class="grid lg:grid-cols-2 gap-8 md:gap-12 items-start">
          <div>
            <p class="font-[Space_Grotesk] text-[0.68rem] font-bold uppercase tracking-[0.2em] text-[#003F87] mb-3">Kaeser / Sopladores</p>
            <h2 class="font-[Space_Grotesk] text-3xl md:text-4xl font-bold tracking-tight text-[#17211c] mb-4">
              Potencia silenciosa. Desde vacío hasta baja presión.
            </h2>
            <p class="text-[#4f5a53] leading-relaxed mb-6">
              Los sopladores KAESER suministran aire de aspiración, soplado o transporte para todas las aplicaciones: transporte neumático de graneles, plantas de tratamiento de aguas, uso industrial y móvil. Eficientes, confiables y con bajas emisiones sonoras.
            </p>
            <div class="space-y-2">
              <details class="group border border-[#0f3d2f]/10 bg-[#f8f6f1] hover:border-[#003F87]/20 transition-colors">
                <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none">
                  <span class="text-sm font-bold text-[#17211c]">Sopladores de lóbulo rotativo OMEGA</span>
                  <span class="material-symbols-outlined text-[#003F87] transition-transform duration-300 group-open:rotate-45 flex-shrink-0" style="font-size:1rem;">add</span>
                </summary>
                <div class="px-5 pb-4 pt-0 text-sm text-[#4f5a53] leading-relaxed">
                  Rotores trilobulares OMEGA de bajas pulsaciones. Capacidad 5–160 m³/min. Uso móvil: camiones de concreto, camiones silo y vehículos aspiradora.
