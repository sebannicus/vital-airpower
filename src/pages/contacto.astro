---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const coverage = [
  { loc: 'Quilacán', role: 'Base técnica principal', icon: 'warehouse', primary: true },
  { loc: 'La Serena', role: 'Cobertura operacional', icon: 'location_on', primary: false },
  { loc: 'Coquimbo', role: 'Cobertura operacional', icon: 'location_on', primary: false },
  { loc: 'Faenas mineras norte chico', role: 'Servicio en terreno', icon: 'landscape', primary: false },
];
---

<BaseLayout
  title="Contacto — Vital Airpower | Asistencia técnica 24/7"
  description="Contacte a Vital Airpower para asistencia técnica, cotizaciones o emergencias industriales. Base en Quilacán, cobertura en La Serena, Coquimbo y norte chico."
>
  <Header />

  <main class="pt-[72px]">

    <!-- HERO -->
    <section class="py-16 px-6 md:px-12 bg-[#F6F3F2]">
      <div class="max-w-[1920px] mx-auto grid md:grid-cols-12 gap-8 items-center">
        <div class="md:col-span-8">
          <span class="animate-hero font-[Space_Grotesk] text-[10px] font-bold uppercase tracking-[0.2em] text-[#003F87] mb-4 block">Asistencia directa</span>
          <h1 class="animate-hero-delay-1 font-[Space_Grotesk] text-5xl md:text-6xl font-bold tracking-tighter text-[#1B1C1C] leading-[1.05] mb-4">
            Canales directos
          </h1>
          <p class="animate-hero-delay-2 text-[#5E5E5E] text-xl max-w-xl">
            Comuníquese directamente con nuestro equipo técnico para asistencia, cotizaciones o emergencias industriales.
          </p>
        </div>
        <div class="animate-hero-delay-3 md:col-span-4 hidden md:flex items-center justify-center">
          <img
            src="/images/logo.png"
            alt="Vital Airpower Compresores"
            width="180"
            height="180"
            class="w-36 h-auto opacity-15"
          />
        </div>
      </div>
    </section>

    <!-- FORMULARIO + CONTACTO DIRECTO -->
    <section class="py-24 px-6 md:px-12">
      <div class="max-w-[1920px] mx-auto grid md:grid-cols-5 gap-12 items-start">

        <!-- Formulario (3/5) -->
        <div class="md:col-span-3 bg-white p-10" style="box-shadow: 0 20px 40px -20px rgba(27,28,28,0.08);" data-animate="fade-left">
          <h2 class="font-[Space_Grotesk] text-2xl font-bold tracking-tighter mb-8">Solicitud técnica</h2>
          <form class="space-y-6" action="#" method="POST">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-xs font-bold uppercase tracking-widest text-[#5E5E5E] mb-2" for="nombre">
                  Nombre completo
                </label>
                <input
                  id="nombre"
                  name="nombre"
                  type="text"
                  required
                  class="w-full border border-[#C2C6D4] px-4 py-3 text-sm focus:outline-none focus:border-[#003F87] transition-colors bg-[#F6F3F2]"
                  placeholder="Juan Pérez"
                />
              </div>
              <div>
                <label class="block text-xs font-bold uppercase tracking-widest text-[#5E5E5E] mb-2" for="empresa">
                  Empresa
                </label>
                <input
                  id="empresa"
                  name="empresa"
                  type="text"
                  class="w-full border border-[#C2C6D4] px-4 py-3 text-sm focus:outline-none focus:border-[#003F87] transition-colors bg-[#F6F3F2]"
                  placeholder="Empresa Industrial S.A."
                />
              </div>
            </div>

            <div>
              <label class="block text-xs font-bold uppercase tracking-widest text-[#5E5E5E] mb-2" for="tipo">
                Tipo de solicitud
              </label>
              <select
                id="tipo"
                name="tipo"
                required
                class="w-full border border-[#C2C6D4] px-4 py-3 text-sm focus:outline-none focus:border-[#003F87] transition-colors bg-[#F6F3F2] appearance-none"
              >
                <option value="" disabled selected>Seleccione una opción...</option>
                <option value="mantenimiento">Mantenimiento programado</option>
                <option value="reparacion">Reparación urgente</option>
                <option value="emergencia">Emergencia (respuesta inmediata)</option>
                <option value="rental">Rental de equipo</option>
                <option value="cotizacion">Cotización de equipo</option>
                <option value="asesoria">Asesoría técnica</option>
              </select>
            </div>

            <div>
              <label class="block text-xs font-bold uppercase tracking-widest text-[#5E5E5E] mb-2" for="descripcion">
                Descripción
              </label>
              <textarea
                id="descripcion"
                name="descripcion"
                rows="5"
                required
                class="w-full border border-[#C2C6D4] px-4 py-3 text-sm focus:outline-none focus:border-[#003F87] transition-colors bg-[#F6F3F2] resize-none"
                placeholder="Especifique marca y modelo del equipo, síntomas o requerimiento..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full flex items-center justify-center gap-3 bg-[#003F87] text-white px-8 py-4 font-bold text-sm tracking-widest uppercase hover:bg-[#0056B3] hover:-translate-y-0.5 transition-all duration-200"
            >
              Enviar solicitud técnica
              <span class="material-symbols-outlined" style="font-size: 1.1rem;">send</span>
            </button>
          </form>
        </div>

        <!-- Contacto directo (2/5) -->
        <div class="md:col-span-2 space-y-6" data-animate="fade-right">

          <!-- Logo + identidad -->
          <div class="bg-[#F6F3F2] p-8 flex items-center gap-6 border-b-4 border-[#003F87]">
            <img
              src="/images/logo.png"
              alt="Vital Airpower Compresores"
              width="80"
              height="80"
              class="h-20 w-auto flex-shrink-0"
            />
            <div>
              <p class="font-[Space_Grotesk] font-black text-[#1B1C1C] text-lg leading-tight">VITAL AIRPOWER</p>
              <p class="text-[#5E5E5E] text-sm">Compresores Industriales</p>
              <div class="flex items-center gap-2 mt-2">
                <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                <span class="text-[0.6rem] font-bold uppercase tracking-widest text-[#5E5E5E]">Disponible 24/7</span>
              </div>
            </div>
          </div>

          <!-- WhatsApp CTA -->
          <div class="bg-[#003F87] text-white p-8">
            <span class="material-symbols-outlined mb-4 block" style="font-size: 2rem;">chat</span>
            <h3 class="font-[Space_Grotesk] text-xl font-bold mb-2">Línea de emergencia directa</h3>
            <p class="text-white/70 text-sm leading-relaxed mb-6">
              Respuesta inmediata para jefes de planta y técnicos en terreno. Disponible 24/7.
            </p>
            <a
              href="https://wa.me/56512244588"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-3 bg-[#25D366] text-white px-6 py-4 font-bold text-sm tracking-widest uppercase hover:scale-105 transition-transform"
            >
              <span class="material-symbols-outlined" style="font-size: 1.1rem;">chat</span>
              Contactar vía WhatsApp
            </a>
          </div>

          <!-- Datos de contacto -->
          <div class="bg-[#F6F3F2] p-8 space-y-5">
            <h3 class="font-[Space_Grotesk] text-xs font-bold uppercase tracking-widest text-[#5E5E5E] mb-4">Datos de contacto</h3>
            <div class="flex items-start gap-3">
              <span class="material-symbols-outlined text-[#003F87] flex-shrink-0" style="font-size: 1.2rem;">call</span>
              <div>
                <p class="text-xs text-[#5E5E5E] uppercase tracking-widest mb-0.5">Teléfono</p>
                <a href="tel:+56512244588" class="font-bold text-[#1B1C1C] hover:text-[#003F87] transition-colors">+56 51 224 4588</a>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="material-symbols-outlined text-[#003F87] flex-shrink-0" style="font-size: 1.2rem;">mail</span>
              <div>
                <p class="text-xs text-[#5E5E5E] uppercase tracking-widest mb-0.5">Email</p>
                <a href="mailto:ops@vitalairpower.cl" class="font-bold text-[#1B1C1C] hover:text-[#003F87] transition-colors">ops@vitalairpower.cl</a>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="material-symbols-outlined text-[#003F87] flex-shrink-0" style="font-size: 1.2rem;">location_on</span>
              <div>
                <p class="text-xs text-[#5E5E5E] uppercase tracking-widest mb-0.5">Taller</p>
                <p class="font-bold text-[#1B1C1C]">Quilacán, Región de Coquimbo, Chile</p>
              </div>
            </div>
          </div>

        </div>

      </div>
    </section>

    <!-- FOTO TALLER -->
    <section class="py-0">
      <div class="max-w-[1920px] mx-auto px-6 md:px-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4" data-animate-stagger>
          <div class="aspect-[4/3] overflow-hidden">
            <img src="/images/manguera-compresor.jpeg" alt="Manguera de compresor industrial" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" width="600" height="450" />
          </div>
          <div class="aspect-[4/3] overflow-hidden">
            <img src="/images/cambio-de-rotores.jpeg" alt="Cambio de rotores en compresor" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" width="600" height="450" />
          </div>
          <div class="aspect-[4/3] overflow-hidden">
            <img src="/images/ingersoll-generador-planta.jpeg" alt="Generador Ingersoll Rand en planta" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" width="600" height="450" />
          </div>
        </div>
      </div>
    </section>

    <!-- COBERTURA REGIONAL -->
    <section class="py-24 px-6 md:px-12 bg-[#F6F3F2]">
      <div class="max-w-[1920px] mx-auto">
        <div class="mb-16" data-animate>
          <h2 class="font-[Space_Grotesk] text-4xl font-bold tracking-tighter mb-3">Despliegue regional</h2>
          <div class="w-20 h-1 bg-[#003F87]"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6" data-animate-stagger>
          {coverage.map(({ loc, role, icon, primary }) => (
            <div class={`p-8 hover:-translate-y-1 transition-transform duration-200 ${primary ? 'bg-[#003F87] text-white' : 'bg-white border border-[#C2C6D4]/30'}`} style={primary ? '' : 'box-shadow: 0 20px 40px -20px rgba(27,28,28,0.08);'}>
              <span class={`material-symbols-outlined mb-4 block ${primary ? '' : 'text-[#0056B3]'}`} style="font-size: 1.5rem;">{icon}</span>
              <h3 class={`font-[Space_Grotesk] text-lg font-bold mb-1 ${primary ? '' : 'text-[#1B1C1C]'}`}>{loc}</h3>
              <p class={`text-xs font-bold uppercase tracking-widest ${primary ? 'text-white/60' : 'text-[#003F87]'}`}>{role}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
