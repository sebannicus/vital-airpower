---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const solutions = [
  {
    title: 'Eficiencia energética',
    text: 'El costo energético domina el ciclo de vida del compresor. Vital Airpower usa esa mirada para levantar oportunidades concretas de mejora.',
  },
  {
    title: 'Recuperación de calor',
    text: 'Kaeser indica que puede recuperarse hasta un 96 por ciento de la energía en forma de calor. Esta mirada sirve para proyectos donde el balance energético importa.',
  },
  {
    title: 'Tratamiento de aire',
    text: 'Secadores refrigerativos, configuraciones de tratamiento y filtros de línea para proteger equipos, procesos y redes.',
  },
  {
    title: 'Control del sistema',
    text: 'SIGMA CONTROL 2 y soluciones de red ayudan a coordinar producción, consumo, eventos y visibilidad operativa.',
  },
  {
    title: 'Proyección de red',
    text: 'Diseño y crecimiento de líneas de aire comprimido con una lógica de sistema y no sólo de equipo suelto.',
  },
  {
    title: 'Aire comprimido a medida',
    text: 'Las soluciones completas se traducen en propuestas adaptadas a demanda real, continuidad y proyección del cliente.',
  },
];
---

<BaseLayout
  title="Soluciones | Vital Airpower para eficiencia, tratamiento y sistemas de aire comprimido"
  description="Soluciones de Vital Airpower para eficiencia energética, tratamiento de aire, control del sistema, líneas de aire comprimido y acompañamiento técnico basado en Kaeser."
>
  <Header />

  <main class="pt-[96px] bg-[#f4f1eb]">
    <section class="py-24 px-6 md:px-12 bg-[#F6F3F2]">
      <div class="max-w-[1440px] mx-auto grid lg:grid-cols-[1fr_0.8fr] gap-12 items-center">
        <div>
          <p class="font-[Space_Grotesk] text-[0.7rem] font-bold uppercase tracking-[0.2em] text-[#003F87] mb-4">Soluciones</p>
          <h1 class="font-[Space_Grotesk] text-4xl md:text-6xl font-bold tracking-tight text-[#1B1C1C] leading-[1.05] mb-6">
            Soluciones de sistema para que el aire comprimido funcione mejor, no solo para que el equipo opere.
          </h1>
          <p class="text-[#5E5E5E] text-xl leading-relaxed max-w-3xl">
            Vital Airpower aplica conceptos de eficiencia, control, tratamiento y soluciones completas a medida desde una oferta práctica para clientes industriales.
          </p>
        </div>
        <div class="aspect-[4/3] overflow-hidden">
          <img src="/images/planta-de-aire.webp" alt="Soluciones de sistema de aire comprimido" class="w-full h-full object-cover" width="900" height="700" />
        </div>
      </div>
    </section>

    <section class="py-24 px-6 md:px-12 bg-white">
      <div class="max-w-[1440px] mx-auto grid md:grid-cols-2 xl:grid-cols-3 gap-5">
        {solutions.map((item) => (
          <article class="bg-[#F6F3F2] border border-[#C2C6D4]/20 p-7 min-h-[220px]">
            <span class="material-symbols-outlined text-[#003F87] mb-5 block" style="font-size: 1.5rem;">tune</span>
            <h3 class="font-[Space_Grotesk] text-xl font-bold text-[#1B1C1C] mb-3">{item.title}</h3>
            <p class="text-[#5E5E5E] leading-relaxed">{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="py-24 px-6 md:px-12 bg-[#17211c] text-white">
      <div class="max-w-[1440px] mx-auto grid md:grid-cols-[0.9fr_1.1fr] gap-12 items-start">
        <div>
          <p class="font-[Space_Grotesk] text-[0.7rem] font-bold uppercase tracking-[0.2em] text-[#d5c6ac] mb-4">Criterio técnico</p>
          <h2 class="font-[Space_Grotesk] text-3xl md:text-5xl font-bold tracking-tight mb-6">
            Más aire comprimido por menos energía, llevado a un lenguaje de proyecto.
          </h2>
          <p class="text-white/72 text-lg leading-relaxed">
            La propuesta considera costo de ciclo de vida, optimización del caudal, recuperación de calor, control de carga parcial, secadores protegidos térmicamente y conectividad del sistema.
          </p>
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          {[
            'Hasta 30 por ciento de potencial de ahorro energético referencial.',
            'Hasta 96 por ciento de recuperación de calor aprovechable.',
            'Secadores refrigerativos en carcasas separadas para mejorar seguridad operativa.',
            'Filtros Kaeser con referencia a pureza de aire bajo ISO 8573-1.',
            'SIGMA NETWORK y control maestro para estaciones más integradas.',
            'Gestión térmica ETM para reducir humedad y daños asociados.',
          ].map((item) => (
            <div class="border border-white/10 bg-white/5 p-6">
              <div class="flex items-start gap-3">
                <span class="material-symbols-outlined text-[#e3d6be]" style="font-size: 1.15rem;">dataset_linked</span>
                <p class="text-white/82 leading-relaxed">{item}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-24 px-6 md:px-12 bg-[#F6F3F2]">
      <div class="max-w-[1200px] mx-auto text-center">
        <h2 class="font-[Space_Grotesk] text-3xl md:text-5xl font-bold tracking-tight text-[#1B1C1C] mb-6">
          El foco es construir mejores decisiones técnicas para cada sistema de aire comprimido.
        </h2>
        <p class="text-[#5E5E5E] text-lg max-w-3xl mx-auto mb-10">
          Vital Airpower se enfoca en eficiencia, tratamiento, control y soluciones que mejoran la operación completa.
        </p>
        <a href="/contacto" class="inline-flex items-center gap-3 bg-[#003F87] text-white px-8 py-4 font-bold text-sm tracking-widest uppercase">
          Solicitar evaluación
          <span class="material-symbols-outlined" style="font-size: 1rem;">arrow_forward</span>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
