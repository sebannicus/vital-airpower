---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const identityCards = [
  {
    title: 'Identidad',
    text: 'Vital Airpower es una empresa de servicios técnicos industriales orientada a mantenimiento, reparación y soporte de compresores, grupos electrógenos y sistemas de aire comprimido.',
  },
  {
    title: 'Ubicación',
    text: 'Base operativa en Quilacán, Región de Coquimbo, con cobertura en La Serena, Coquimbo y faenas mineras del norte chico.',
  },
  {
    title: 'Experiencia',
    text: 'Más de 25 años en terreno atendiendo operaciones que no pueden detenerse por una falla en aire comprimido.',
  },
];

const differentiators = [
  '25+ años de experiencia real en terreno.',
  'Taller propio en Quilacán para diagnóstico y soporte.',
  'Contingencia 24/7 orientada a continuidad operacional.',
  'Distribuidor oficial Kaeser Chile.',
  'Conocimiento regional del norte chico y sus exigencias operativas.',
];

const kaeserSignals = [
  'Kaeser fabrica compresores de tornillo reconocidos por eficiencia energética y confiabilidad de largo plazo en entornos industriales exigentes.',
  'Como distribuidores oficiales en Chile, tenemos acceso directo al catálogo completo y al soporte técnico de la marca.',
  'Si su operación necesita un equipo, usted habla con nosotros: evaluamos la aplicación, identificamos el modelo y lo gestionamos.',
];

const leadBlocks = [
  {
    title: 'Jefe de mantenimiento',
    text: 'Necesita respuesta rápida, experiencia comprobada y una conversación técnica sin promesas vacías.',
  },
  {
    title: 'Encargado de planta',
    text: 'Busca continuidad operacional, orden en el sistema y soporte para tomar decisiones con más contexto.',
  },
  {
    title: 'Operación minera o industrial',
    text: 'Valora cobertura regional, criterio de terreno y capacidad real para actuar frente a una parada no programada.',
  },
];

const carouselImages = [
  { src: '/images/hero-kaeser.webp',          alt: 'Compresor Kaeser en entorno industrial' },
  { src: '/images/kaeser-csd105.webp',         alt: 'Kaeser CSD 105' },
  { src: '/images/kaeser-ask32t.webp',         alt: 'Kaeser ASK 32 T' },
  { src: '/images/kaeser-sk25t.webp',          alt: 'Kaeser SK 25 T' },
  { src: '/images/kaeser-sm12.webp',           alt: 'Kaeser SM 12' },
  { src: '/images/compresor-planta.webp',      alt: 'Compresor en planta industrial' },
  { src: '/images/planta-de-aire.webp',        alt: 'Sala de compresores' },
  { src: '/images/cambio-de-filtro.webp',      alt: 'Cambio de filtro en compresor' },
  { src: '/images/cambio-de-rotores.webp',     alt: 'Cambio de rotores' },
  { src: '/images/filtro-compresor.webp',      alt: 'Filtro de línea' },
  { src: '/images/limpieza-mantencion.webp',   alt: 'Mantención técnica en planta' },
  { src: '/images/limpieza-mantencion-2.webp', alt: 'Servicio técnico en terreno' },
  { src: '/images/manguera-compresor.webp',    alt: 'Líneas de aire comprimido' },
  { src: '/images/motor-de-compresor.webp',    alt: 'Motor de compresor industrial' },
  { src: '/images/rotores.webp',               alt: 'Rotores de compresor de tornillo' },
];
---

<BaseLayout
  title="Empresa | Vital Airpower y distribución oficial Kaeser Chile"
  description="Perfil corporativo de Vital Airpower como empresa de servicios técnicos industriales y distribuidor oficial Kaeser Chile, con base en Quilacán y cobertura en el norte chico."
>
  <Header />

  <main class="pt-[96px] bg-[#f4f1eb]">
    <section class="relative overflow-hidden border-b border-[#0f3d2f]/10 bg-[linear-gradient(135deg,#f4f1eb_0%,#ebe7df_54%,#ddd4c6_100%)]">
      <div class="absolute inset-0 opacity-[0.08] pointer-events-none bg-[radial-gradient(circle_at_top_left,_#0f3d2f_0,_transparent_32%),radial-gradient(circle_at_bottom_right,_#003F87_0,_transparent_28%)]"></div>
      <div class="relative max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28 grid lg:grid-cols-[1fr_0.85fr] gap-12 items-center">
        <div>
          <p class="font-[Space_Grotesk] text-[0.72rem] font-bold uppercase tracking-[0.2em] text-[#003F87] mb-5">Sobre Nosotros</p>
          <h1 class="font-[Space_Grotesk] text-4xl md:text-6xl font-bold tracking-tight text-[#17211c] leading-[1.02] mb-6">
            Vital Airpower respalda operaciones industriales donde una parada no programada cuesta demasiado.
          </h1>
          <p class="text-[#3f4a43] text-lg md:text-xl leading-relaxed mb-10">
            Servicios técnicos industriales para compresores, grupos electrógenos y sistemas de aire comprimido, con más de 25 años de experiencia, taller propio en Quilacán y distribución oficial Kaeser Chile.
          </p>
          <div class="grid sm:grid-cols-3 gap-4">
            <div class="border border-[#0f3d2f]/10 bg-white/70 px-5 py-5">
              <p class="text-[0.68rem] uppercase tracking-[0.18em] font-bold text-[#7a6b57] mb-2">Base operativa</p>
              <p class="text-2xl font-bold text-[#17211c]">Quilacán</p>
              <p class="text-sm text-[#546056]">Región de Coquimbo</p>
            </div>
            <div class="border border-[#0f3d2f]/10 bg-white/70 px-5 py-5">
              <p class="text-[0.68rem] uppercase tracking-[0.18em] font-bold text-[#7a6b57] mb-2">Experiencia</p>
              <p class="text-2xl font-bold text-[#17211c]">25+</p>
              <p class="text-sm text-[#546056]">años en terreno</p>
            </div>
            <div class="border border-[#0f3d2f]/10 bg-white/70 px-5 py-5">
              <p class="text-[0.68rem] uppercase tracking-[0.18em] font-bold text-[#7a6b57] mb-2">Cobertura</p>
              <p class="text-2xl font-bold text-[#17211c]">La Serena</p>
              <p class="text-sm text-[#546056]">Coquimbo y norte chico</p>
            </div>
          </div>
        </div>

        <!-- Imagen placeholder — reemplazar src por foto real -->
        <div class="hidden lg:block relative overflow-hidden h-[540px] bg-[#1c2320] border border-[#0f3d2f]/20">
          <img
            src="/images/planta-de-aire.webp"
            alt="Vital Airpower — operación industrial"
            class="absolute inset-0 w-full h-full object-cover opacity-80"
            width="900"
            height="1080"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#1c2320]/60 via-transparent to-transparent"></div>
        </div>
      </div>
    </section>

    <section class="py-24 px-6 md:px-12 bg-white">
      <div class="max-w-[1440px] mx-auto">
        <div class="grid lg:grid-cols-[0.95fr_1.05fr] gap-12 items-start mb-16">
          <div>
            <p class="font-[Space_Grotesk] text-[0.72rem] font-bold uppercase tracking-[0.2em] text-[#7a6b57] mb-4">Vital Airpower</p>
            <h2 class="font-[Space_Grotesk] text-3xl md:text-5xl font-bold tracking-tight text-[#1B1C1C] mb-6">
              Una empresa construida para responder con experiencia real, no con promesas vacías.
            </h2>
            <p class="text-[#5E5E5E] text-lg leading-relaxed mb-8">
              Vital Airpower nace desde una experiencia técnica acumulada en terreno, orientada a resolver fallas, sostener la continuidad operacional y acompañar decisiones de mantenimiento en operaciones mineras e industriales. La propuesta combina servicio, criterio técnico y respaldo de marca en un formato corporativo directo y confiable.
            </p>
            <div class="space-y-4">
              {differentiators.map((item) => (
                <div class="flex items-start gap-3">
                  <span class="material-symbols-outlined text-[#003F87]" style="font-size: 1.15rem;">check_circle</span>
                  <p class="text-[#1B1C1C] leading-relaxed">{item}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="grid md:grid-cols-3 gap-5">
            {identityCards.map((card) => (
              <article class="bg-[#F6F3F2] border border-[#C2C6D4]/20 p-7 min-h-[240px]">
                <p class="text-[0.72rem] uppercase tracking-[0.18em] font-bold text-[#7a6b57] mb-3">{card.title}</p>
                <p class="text-[#1B1C1C] leading-relaxed">{card.text}</p>
              </article>
            ))}
          </div>
        </div>

        <!-- Imagen grande Kaeser -->
        <div class="relative overflow-hidden h-[480px] md:h-[580px] border border-[#C2C6D4]/20 bg-[#17211c]">
          <img
            src="/images/hero-kaeser.webp"
            alt="Kaeser — tecnología de aire comprimido industrial"
            class="absolute inset-0 w-full h-full object-cover opacity-75"
            width="1920"
            height="1080"
          />
          <div class="absolute inset-0 bg-gradient-to-r from-[#17211c]/80 via-[#17211c]/30 to-transparent"></div>
          <div class="relative z-10 h-full flex flex-col justify-end p-10 md:p-16">
            <img src="/images/logo-kaeser.webp" alt="Kaeser" width="168" height="44" class="h-9 w-auto object-contain mb-5 opacity-90" />
            <p class="text-white font-[Space_Grotesk] text-2xl md:text-3xl font-bold max-w-lg leading-snug">
              Tecnología de aire comprimido respaldada por más de 100 años de desarrollo propio.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 px-6 md:px-12 bg-[#F6F3F2]">
      <div class="max-w-[1440px] mx-auto grid md:grid-cols-2 gap-12 items-start">
        <div>
          <p class="font-[Space_Grotesk] text-[0.72rem] font-bold uppercase tracking-[0.2em] text-[#7a6b57] mb-4">Publico objetivo</p>
          <h2 class="font-[Space_Grotesk] text-3xl md:text-5xl font-bold tracking-tight text-[#1B1C1C] mb-6">
            Hablamos con quienes cargan la presión de mantener la planta operando.
          </h2>
          <p class="text-[#5E5E5E] text-lg leading-relaxed">
            El cliente ideal de Vital Airpower no busca marketing técnico. Busca experiencia comprobada, lectura honesta del problema y una respuesta que ayude a evitar nuevas detenciones del proceso.
          </p>
        </div>
        <div class="grid gap-4">
          {leadBlocks.map((item) => (
            <article class="bg-white border border-[#C2C6D4]/20 p-6">
              <h3 class="font-[Space_Grotesk] text-2xl font-bold text-[#1B1C1C] mb-3">{item.title}</h3>
              <p class="text-[#5E5E5E] leading-relaxed">{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="py-24 px-6 md:px-12 bg-white">
      <div class="max-w-[1440px] mx-auto grid md:grid-cols-2 gap-12 items-start">
        <div>
          <p class="font-[Space_Grotesk] text-[0.72rem] font-bold uppercase tracking-[0.2em] text-[#003F87] mb-4">Kaeser como protagonista</p>
          <h2 class="font-[Space_Grotesk] text-3xl md:text-5xl font-bold tracking-tight text-[#1B1C1C] mb-6">
            Si su operación necesita un Kaeser, tiene a alguien que lo consigue.
          </h2>
          <p class="text-[#5E5E5E] text-lg leading-relaxed mb-8">
            Vital Airpower es distribuidor oficial Kaeser Chile. Si necesita un compresor, no navega el proceso solo — usted habla con nosotros, evaluamos la aplicación juntos e identificamos el equipo que corresponde. Sin intermediarios, sin letra chica.
          </p>
          <div class="space-y-4">
            {kaeserSignals.map((item) => (
              <div class="bg-[#F6F3F2] border border-[#C2C6D4]/20 p-6">
                <div class="flex items-start gap-3">
                  <span class="material-symbols-outlined text-[#003F87]" style="font-size: 1.2rem;">verified</span>
                  <p class="text-[#1B1C1C] leading-relaxed">{item}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div id="empresa-carousel" class="relative overflow-hidden min-h-[560px] border border-[#C2C6D4]/20 bg-[#17211c] select-none">
          {carouselImages.map((img, i) => (
            <div
              class="carousel-slide absolute inset-0 transition-opacity duration-700"
              style={i === 0 ? 'opacity:1;z-index:1' : 'opacity:0;z-index:0'}
            >
              <img
                src={img.src}
                alt={img.alt}
                class="absolute inset-0 h-full w-full object-cover"
                loading={i === 0 ? 'eager' : 'lazy'}
              />
            </div>
          ))}

          <button
            id="carousel-prev"
            aria-label="Foto anterior"
            class="absolute left-4 top-1/2 -translate-y-1/2 z-20 flex items-center justify-center w-10 h-10 bg-black/40 hover:bg-[#003F87] text-white transition-colors duration-200"
          >
            <span class="material-symbols-outlined" style="font-size:1.25rem;">chevron_left</span>
          </button>

          <button
            id="carousel-next"
            aria-label="Foto siguiente"
            class="absolute right-4 top-1/2 -translate-y-1/2 z-20 flex items-center justify-center w-10 h-10 bg-black/40 hover:bg-[#003F87] text-white transition-colors duration-200"
          >
            <span class="material-symbols-outlined" style="font-size:1.25rem;">chevron_right</span>
          </button>

          <div class="absolute bottom-4 right-5 z-20 font-[Space_Grotesk] text-[0.65rem] font-bold uppercase tracking-widest text-white/60">
            <span id="carousel-current">1</span> / {carouselImages.length}
          </div>
        </div>

        <script>
          (() => {
            const carousel = document.getElementById('empresa-carousel');
            if (!carousel) return;
            const slides = carousel.querySelectorAll('.carousel-slide');
            const counter = document.getElementById('carousel-current');
            let current = 0;
            let timer: ReturnType<typeof setInterval>;

            function goTo(index: number) {
              slides[current].style.opacity = '0';
              (slides[current] as HTMLElement).style.zIndex = '0';
              current = (index + slides.length) % slides.length;
              slides[current].style.opacity = '1';
              (slides[current] as HTMLElement).style.zIndex = '1';
              if (counter) counter.textContent = String(current + 1);
            }

            function startAuto() {
              timer = setInterval(() => goTo(current + 1), 4000);
            }

            function resetAuto() {
              clearInterval(timer);
              startAuto();
            }

            document.getElementById('carousel-prev')?.addEventListener('click', () => { goTo(current - 1); resetAuto(); });
            document.getElementById('carousel-next')?.addEventListener('click', () => { goTo(current + 1); resetAuto(); });

            startAuto();
          })();
        </script>
      </div>
    </section>

    <section class="py-24 px-6 md:px-12 bg-[#17211c] text-white">
      <div class="max-w-[1200px] mx-auto text-center">
        <h2 class="font-[Space_Grotesk] text-3xl md:text-5xl font-bold tracking-tight mb-6">
          Vital Airpower combina servicio técnico, taller propio, contingencia y acceso directo a Kaeser Chile dentro de una misma propuesta seria.
        </h2>
        <p class="text-white/72 text-lg max-w-3xl mx-auto mb-10">
          Para jefes de mantenimiento y encargados técnicos, eso significa menos promesa vacía y más capacidad real para resolver, proyectar y mantener la operación.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="/servicios" class="inline-flex items-center gap-3 bg-white text-[#003F87] px-8 py-4 font-bold text-sm tracking-widest uppercase">
            Ver servicios
            <span class="material-symbols-outlined" style="font-size: 1rem;">arrow_forward</span>
          </a>
          <a href="https://wa.me/56976400195" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 bg-[#25D366] text-white px-8 py-4 font-bold text-sm tracking-widest uppercase">
            <span class="material-symbols-outlined" style="font-size: 1rem;">chat</span>
            WhatsApp técnico
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
