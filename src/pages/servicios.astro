---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const services = [
  {
    title: 'Servicio técnico de compresores',
    text: 'Diagnóstico, mantención y soporte para compresores industriales con foco en continuidad y criterio de sistema.',
  },
  {
    title: 'Secadores de aire',
    text: 'Atención a secadores por refrigeración y por absorción según la calidad de aire requerida por el proceso.',
  },
  {
    title: 'Filtros y tratamiento de aire',
    text: 'Soporte sobre filtros de línea, protección del sistema y calidad de aire para procesos sensibles.',
  },
  {
    title: 'Líneas de aire comprimido',
    text: 'Creación, mantención y proyección de redes de aire para crecimiento ordenado de la operación.',
  },
  {
    title: 'Auditorías de fugas',
    text: 'Levantamiento por ultrasonido para detectar pérdidas y encontrar mejoras de eficiencia.',
  },
  {
    title: 'Stock crítico',
    text: 'Planificación y control de repuestos para clientes con contratos de servicio o mantenimiento.',
  },
];

const supportSignals = [
  'SIGMA CONTROL 2 coordina producción y consumo de aire comprimido para evitar derroches en carga parcial.',
  'El controlador registra eventos de servicio, admite actualizaciones y permite visualizar datos operativos.',
  'Vital Airpower toma ese soporte de control para acompañar decisiones de mantenimiento y administración del sistema.',
];
---

<BaseLayout
  title="Servicios | Vital Airpower para compresores, tratamiento de aire y soporte técnico"
  description="Servicios de Vital Airpower para compresores industriales, secadores, filtros, líneas de aire, auditorías de fuga, eficiencia energética y stock crítico."
>
  <Header />

  <main class="pt-[96px] bg-[#f4f1eb]">
    <section class="py-24 px-6 md:px-12 bg-[#F6F3F2]">
      <div class="max-w-[1440px] mx-auto grid lg:grid-cols-[1fr_0.8fr] gap-12 items-center">
        <div>
          <p class="font-[Space_Grotesk] text-[0.7rem] font-bold uppercase tracking-[0.2em] text-[#003F87] mb-4">Servicios</p>
          <h1 class="font-[Space_Grotesk] text-4xl md:text-6xl font-bold tracking-tight text-[#1B1C1C] leading-[1.05] mb-6">
            Servicios para la operación diaria del sistema de aire comprimido.
          </h1>
          <p class="text-[#5E5E5E] text-xl leading-relaxed max-w-3xl">
            Servicio técnico, tratamiento de aire, líneas, eficiencia, soporte y administración para empresas que necesitan continuidad operacional y una respuesta clara.
          </p>
        </div>
        <div class="aspect-[4/3] overflow-hidden">
          <img src="/images/servicios-portada3.webp" alt="Servicio técnico Vital Airpower" class="w-full h-full object-cover" width="900" height="700" />
        </div>
      </div>
    </section>

    <section class="py-24 px-6 md:px-12 bg-white">
      <div class="max-w-[1440px] mx-auto">
        <div class="max-w-3xl mb-12">
          <h2 class="font-[Space_Grotesk] text-3xl md:text-5xl font-bold tracking-tight text-[#1B1C1C] mb-6">
            Capacidades técnicas alineadas con la propuesta de Vital Airpower.
          </h2>
        </div>
        <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-5">
          {services.map((service) => (
            <article class="bg-[#F6F3F2] border border-[#C2C6D4]/20 p-7 min-h-[220px]">
              <span class="material-symbols-outlined text-[#003F87] mb-5 block" style="font-size: 1.5rem;">handyman</span>
              <h3 class="font-[Space_Grotesk] text-xl font-bold text-[#1B1C1C] mb-3">{service.title}</h3>
              <p class="text-[#5E5E5E] leading-relaxed">{service.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="py-24 px-6 md:px-12 bg-[#17211c] text-white">
      <div class="max-w-[1440px] mx-auto grid md:grid-cols-2 gap-12 items-start">
        <div>
          <p class="font-[Space_Grotesk] text-[0.7rem] font-bold uppercase tracking-[0.2em] text-[#d5c6ac] mb-4">Control y seguimiento</p>
          <h2 class="font-[Space_Grotesk] text-3xl md:text-5xl font-bold tracking-tight mb-6">
            SIGMA CONTROL 2 aporta contexto técnico; el servicio lo aterriza Vital Airpower.
          </h2>
          <p class="text-white/72 text-lg leading-relaxed">
            El control, la lectura operativa y el ajuste inteligente se traducen en acompañamiento sobre paneles, seguimiento de variables y mejor capacidad para tomar decisiones de mantenimiento o administración.
          </p>
        </div>
        <div class="space-y-4">
          {supportSignals.map((item) => (
            <div class="border border-white/10 bg-white/5 p-6">
              <div class="flex items-start gap-3">
                <span class="material-symbols-outlined text-[#e3d6be]" style="font-size: 1.15rem;">memory</span>
                <p class="text-white/82 leading-relaxed">{item}</p>
              </div>
            </div>
          ))}
          <div class="border border-[#c79a3b]/35 bg-[#c79a3b]/10 p-6">
            <p class="text-white/82 leading-relaxed">
              Cuando aplica, Vital Airpower puede apoyar lectura de sistemas, paneles de administración y seguimiento operativo ligado a Sigma Control 2.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 px-6 md:px-12 bg-[#F6F3F2]">
      <div class="max-w-[1200px] mx-auto text-center">
        <h2 class="font-[Space_Grotesk] text-3xl md:text-5xl font-bold tracking-tight text-[#1B1C1C] mb-6">
          Servicio pensado para clientes que no buscan sólo una marca, sino continuidad operacional.
        </h2>
        <p class="text-[#5E5E5E] text-lg max-w-3xl mx-auto mb-10">
          El valor está en combinar equipo correcto, soporte técnico, calidad de aire, eficiencia y una relación comercial que anticipe necesidades de la operación.
        </p>
        <a href="/contacto" class="inline-flex items-center gap-3 bg-[#003F87] text-white px-8 py-4 font-bold text-sm tracking-widest uppercase">
          Hablar con un técnico
          <span class="material-symbols-outlined" style="font-size: 1rem;">arrow_forward</span>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
