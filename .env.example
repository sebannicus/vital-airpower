# ============================================
# Vital Airpower — Variables de entorno
# Copiar este archivo como .env y completar
# Configurar también en Vercel Dashboard > Settings > Environment Variables
# ============================================

# Google Analytics 4 — Measurement ID
# Obtener en: analytics.google.com > Admin > Data Streams
PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Tag Manager — Container ID
# Obtener en: tagmanager.google.com
PUBLIC_GTM_ID=GTM-XXXXXXX
